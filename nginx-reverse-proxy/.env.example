# Configuration d'exemple pour le Reverse Proxy Nginx

# Domaines (remplacer par vos vrais domaines)
NODE_DOMAIN=api.example.com
PYTHON_DOMAIN=app.example.com
PHP_DOMAIN=web.example.com

# Email pour Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com

# Ports
HTTP_PORT=80
HTTPS_PORT=443
NODE_PORT=3000
PYTHON_PORT=5000

# Environnements
NODE_ENV=production
FLASK_ENV=production
PHP_ENV=production
